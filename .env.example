# WalkieTalk Go backend env for Render
PORT=3000
ENV=production

# Frontend is hosted separately on Vercel. Put your Vercel domain here.
# For testing only, you may use: CORS_ORIGINS=*
CORS_ORIGINS=https://your-vercel-app.vercel.app,http://localhost:3000,http://localhost:5173

# Optional backend/admin key. Leave empty for the public frontend.
PUBLIC_API_KEY=
# Public zone writes are device-scoped. Set true only for private/admin deployments.
ZONE_WRITE_REQUIRES_API_KEY=false

# Mapbox public pk token only. No quotes and no newline.
MAPBOX_ACCESS_TOKEN=pk_your_public_mapbox_token
MAPBOX_STANDARD_STYLE=mapbox://styles/mapbox/standard
MAPBOX_STANDARD_SATELLITE_STYLE=mapbox://styles/mapbox/standard-satellite
PUBLIC_CONFIG_CACHE_SECS=300

# Redis is optional and used for distributed rate limits.
REDIS_ENABLED=true
REDIS_URL=redis://default:replace-with-rotated-password@your-redis-host:6379
REDIS_CIRCUIT_OPEN_SECS=15
REDIS_FAILURE_THRESHOLD=3

# Supabase REST. Use a backend-only service_role key when RLS is enabled.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-backend-service-role-key

# Limits
MAX_ROOM_SIZE=20
MAX_AUDIO_BYTES=8000000
MAX_DURATION=65
MAX_MSG_RATE=4
MSG_RATE_WINDOW=10
MAX_CHUNK_BYTES=220000
MAX_CHUNK_RATE=40
MAX_ZONE_READ_RATE=60
MAX_ZONE_WRITE_RATE=20
ZONE_TTL_SECS=18000
CHANNEL_EMPTY_TTL_SECS=900
