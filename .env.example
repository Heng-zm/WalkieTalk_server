# Server
PORT=3000
ENV=production
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
PUBLIC_API_KEY=change-this-admin-client-key

# AI backend - rotate any key that was pasted in chat
AI_API_KEY=replace-with-new-rotated-key
AI_ASSISTANT_API_KEY=replace-with-new-rotated-key
AI_ASSISTANT_URL=https://bot-voice-sqnz.onrender.com/ai-assistant
AI_CHAT_URL=
AI_TIMEOUT_SECS=45
AI_CHAT_TIMEOUT_SECS=45

# Mapbox public pk token only. No quotes, no \n.
MAPBOX_ACCESS_TOKEN=pk_your_public_mapbox_token
MAPBOX_STANDARD_STYLE=mapbox://styles/mapbox/standard
MAPBOX_STANDARD_SATELLITE_STYLE=mapbox://styles/mapbox/standard-satellite
PUBLIC_CONFIG_CACHE_SECS=300

# Redis is optional in this Go version and currently used for distributed rate limits.
REDIS_ENABLED=true
REDIS_URL=redis://default:replace-with-rotated-password@your-redis-host:6379
REDIS_CIRCUIT_OPEN_SECS=15
REDIS_FAILURE_THRESHOLD=3

# Supabase REST
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key

# Limits
MAX_ROOM_SIZE=20
MAX_AUDIO_BYTES=8000000
MAX_DURATION=65
MAX_MSG_RATE=4
MSG_RATE_WINDOW=10
MAX_CHUNK_BYTES=220000
MAX_CHUNK_RATE=40
MAX_AI_TEXT_LEN=2000
MAX_AI_HISTORY=12
MAX_AI_CHAT_RATE=8
MAX_SCREEN_SIGNAL_RATE=50
MAX_SCREEN_SDP_CHARS=80000
MAX_SCREEN_ICE_CHARS=16000
SCREEN_STATE_TTL=21600
ZONE_TTL_SECS=18000
